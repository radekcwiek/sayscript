# Default: let Git detect text files.
* text=auto

# Linux/macOS shell scripts must always use LF.
*.sh text eol=lf

# Source and documentation files.
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.ini text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.spec text eol=lf

# Windows command scripts.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files must never be line-ending-normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
